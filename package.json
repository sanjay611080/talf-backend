{
  "name": "talf-solar-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend API for the Talf Solar MIS frontend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
