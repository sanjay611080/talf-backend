generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  username     String  @id
  role         String
  fullName     String?
  email        String?
  contact      String?
  isActive     Boolean @default(true)
  passwordHash String
}

model Project {
  projectCode         String  @id
  projectState        String
  projectName         String
  projectOwner        String
  dateOfCommissioning String
  tariff              Float
  plantId             String?
  // Solis lifetime roll-up (station.allEnergy) — includes replaced inverters and pre-registration history.
  lifetimeKWh         Float?
  inverters           Json
  monthlyData         Json
  breakdownEvents     Json
}

model ModuleBuild {
  id          String @id
  name        String
  wp          Float
  area        Float
  degradation Json
}

model SolisCredentials {
  id        Int    @id @default(1)
  apiId     String
  apiSecret String
  baseUrl   String
}

model AppMeta {
  key   String @id
  value String
}

// Persistent audit trail — written directly via Prisma, not through the in-memory store.
model AuditLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  performedBy String
  action      String
  entityType  String
  entityId    String?
  entityLabel String?
  description String
  changes     Json?
  metadata    Json?

  @@index([timestamp(sort: Desc)])
  @@index([performedBy])
  @@index([entityType])
  @@index([action])
}
