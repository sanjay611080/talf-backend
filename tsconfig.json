{
  "compilerOptions": {
    "target": "ES2020",
    // Node16 module + resolution: TS treats files as CommonJS (because
    // package.json has no "type": "module"), so relative imports stay
    // extensionless. Replaces the deprecated "Node" (node10) resolution
    // mode without changing runtime behaviour.
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true
  },
  "include": ["src"]
}
