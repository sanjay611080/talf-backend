# Copy this file to .env and adjust as needed.
PORT=4000
JWT_SECRET=talf-solar-dev-secret-change-me
JWT_EXPIRES_SECONDS=604800

# --- SolisCloud API ---
# From soliscloud.com -> Account -> Basic Settings -> API Management.
# When set here, these take precedence over credentials saved via the UI.
SOLIS_API_ID=
SOLIS_API_SECRET=
SOLIS_BASE_URL=https://www.soliscloud.com:13333

# Fetch projects from SolisCloud automatically on startup (true/false).
SOLIS_AUTO_SYNC=true
# Skip the startup sync if one completed within this many hours.
SOLIS_SYNC_TTL_HOURS=6
